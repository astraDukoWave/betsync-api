# ==============================================================
# betsync-api — Environment Variables
# ==============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# ==============================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=betsync
POSTGRES_PASSWORD=betsync_pass
POSTGRES_DB=betsync

# Async DSN (FastAPI / Alembic)
DATABASE_URL=postgresql+asyncpg://betsync:betsync_pass@postgres:5432/betsync
# Sync DSN (Celery worker)
DATABASE_URL_SYNC=postgresql+psycopg2://betsync:betsync_pass@postgres:5432/betsync

# ── Redis ──────────────────────────────────────────────────────
# DB 0 = cache, DB 1 = Celery broker, DB 2 = Celery results
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── FastAPI / Security ─────────────────────────────────────────
SECRET_KEY=changeme_in_production
DEBUG=false

# ── Odds API (external) ────────────────────────────────────────
# https://the-odds-api.com — free tier: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ── Dashboard cache TTL ────────────────────────────────────────
DASHBOARD_CACHE_TTL=300
