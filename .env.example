# ==============================================================
# betsync-api — Environment Variables
# ==============================================================
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env
#
# POSTGRES_PASSWORD and SECRET_KEY have no defaults.
# docker-compose will fail if they are empty.
# ==============================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=betsync
POSTGRES_PASSWORD=                  # REQUIRED — choose a strong password
POSTGRES_DB=betsync
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async DSN used by SQLAlchemy / Alembic
DATABASE_URL=postgresql+asyncpg://betsync:CHANGE_ME@postgres:5432/betsync

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# DB 0 = cache, DB 1 = Celery broker, DB 2 = job-status results
REDIS_CACHE_DB=0
REDIS_BROKER_DB=1
REDIS_RESULTS_DB=2

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── FastAPI / Security ─────────────────────────────────────────
SECRET_KEY=                         # REQUIRED — generate with: openssl rand -hex 32
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Odds API (external) ────────────────────────────────────────
# https://the-odds-api.com — free tier: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ── Celery / Pipeline ──────────────────────────────────────────
# Hours at which the pipeline auto-runs (comma-separated, 24h UTC)
PIPELINE_RUN_HOURS=08:00,14:00
# Max retries for Odds API calls (tenacity)
ODDS_API_MAX_RETRIES=3
ODDS_API_RETRY_WAIT=2

# ── Dashboard cache TTL ────────────────────────────────────────
DASHBOARD_CACHE_TTL=300            # seconds (default: 5 minutes)

# ── Alembic (only needed outside Docker) ───────────────────────
# When running alembic locally (not in container), set this to the
# localhost equivalent of DATABASE_URL:
# DATABASE_URL=postgresql+asyncpg://betsync:CHANGE_ME@localhost:5432/betsync
